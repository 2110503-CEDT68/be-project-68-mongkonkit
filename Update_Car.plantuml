@startuml
actor Admin
participant "Car Route" as Route
participant "Auth Middleware" as Auth
participant "Car Controller" as Controller
participant "Car Model" as Model

Admin -> Route : PUT /cars/{id}
Route -> Auth : protect()
Auth -> Auth : verify JWT
Auth -> Auth : authorize('admin')
Auth --> Route : next()

Route -> Controller : updateCar(id)
Controller -> Model : findByIdAndUpdate(id, data)
Model --> Controller : updatedCar
Controller --> Admin : 200 OK (car)

@enduml
